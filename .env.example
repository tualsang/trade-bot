# Copy this file to .env and fill in real values. NEVER commit the real .env.

# Alpaca credentials.
#  - PAPER: generate from app.alpaca.markets -> Paper Trading -> API Keys
#  - LIVE : generate from app.alpaca.markets -> Live account -> API Keys (different keys!)
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here

# Trading endpoint.
#  - PAPER: https://paper-api.alpaca.markets
#  - LIVE : https://api.alpaca.markets   <-- real money
ALPACA_PAPER_URL=https://paper-api.alpaca.markets

# Optional: market-data feed for the backtest. 'iex' (free) or 'sip' (paid subscription).
# ALPACA_DATA_FEED=iex

# Optional: starting equity for the backtest simulation (default 100000).
# BACKTEST_EQUITY=100000
