# Copy this file to .env and fill in real values. NEVER commit the real .env.

# Alpaca credentials.
#  - PAPER: generate from app.alpaca.markets -> Paper Trading -> API Keys
#  - LIVE : generate from app.alpaca.markets -> Live account -> API Keys (different keys!)
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here

# Trading endpoint.
#  - PAPER: https://paper-api.alpaca.markets
#  - LIVE : https://api.alpaca.markets   <-- real money
ALPACA_PAPER_URL=https://paper-api.alpaca.markets

# Optional: market-data feed for the backtest. 'iex' (free) or 'sip' (paid subscription).
# ALPACA_DATA_FEED=iex

# Optional: starting equity for the backtest simulation (default 100000).
# BACKTEST_EQUITY=100000

# ============ Optional features ============

# --- Alerts (#3) ---
# Telegram (free): @BotFather -> /newbot for the token; message the bot, then
# open https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# SMS via Twilio (optional, costs money). Set ALL four to enable.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1XXXXXXXXXX
# TWILIO_TO=+1XXXXXXXXXX

# --- Max daily-loss kill switch (#1) ---
# Fraction of day-start equity. 0.05 = flatten + pause if down 5% intraday. 0 = off.
MAX_DAILY_LOSS_PCT=0.00

# --- Earnings blackout (#2) ---
# Free Finnhub key enables skipping buys for stocks reporting tonight / next AM.
FINNHUB_API_KEY=
# true = skip ALL buys if earnings data can't be fetched (safer; halts on API outage).
EARNINGS_FAIL_CLOSED=false
