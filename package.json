{
  "name": "close-open-arbitrage-bot",
  "version": "1.0.0",
  "description": "Alpaca market close/open arbitrage trading bot for SPY, MU, and SNDK (paper trading)",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/main.js",
    "buy-now": "node -e \"require('./src/strategies/close_open_strat').runBuy().then(()=>process.exit(0))\"",
    "sell-now": "node -e \"require('./src/strategies/close_open_strat').runSell().then(()=>process.exit(0))\"",
    "backtest": "node src/backtest/index.js"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "dotenv": "^16.4.5",
    "node-schedule": "^2.1.1"
  },
  "engines": {
    "node": ">=16.9"
  }
}
